PORT=8787
# Bind to loopback when a reverse proxy such as Tailscale Serve runs locally.
HOST=127.0.0.1
# Article metadata and generated audio are stored here.
DATA_DIR=.data
# Optional shared secret. The iOS app sends it as a Bearer token.
API_TOKEN=

# Required for article audio generation.
TTS_PROVIDER=openai
OPENAI_API_KEY=
# Optional AI cleanup uses Codex CLI with shell and web tools disabled.
CODEX_PATH=codex
# Leave empty to use the Codex CLI default model.
CODEX_CLEANUP_MODEL=
# Quality-first default. Use tts-1 for lower latency and cost.
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=alloy
# Maximum 3500; leaves headroom below the Speech API input limit.
OPENAI_TTS_CHUNK_CHARS=3500
# Number of speech chunks generated in parallel.
OPENAI_TTS_CONCURRENCY=10
# Silence inserted between generated chunks for either provider.
TTS_GAP_MS=350

# Speechify alternative. Set TTS_PROVIDER=speechify to use it.
SPEECHIFY_API_KEY=
SPEECHIFY_TTS_MODEL=simba-3.2
SPEECHIFY_TTS_VOICE=hugh_32
# The streaming endpoint supports 20,000 characters; leave some headroom.
SPEECHIFY_TTS_CHUNK_CHARS=18000
SPEECHIFY_TTS_CONCURRENCY=1
